{
  "name": "femo-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build --dotenv .env.lingaphone",
    "build:femo": "nuxt build --dotenv .env.femo",
    "build:lingaphone": "nuxt build --dotenv .env.lingaphone",
    "dev": "nuxt dev --dotenv .env.lingaphone",
    "dev:femo": "nuxt dev --dotenv .env.femo",
    "dev:lingaphone": "nuxt dev --dotenv .env.lingaphone",
    "preview": "nuxt preview --dotenv .env.lingaphone",
    "preview:femo": "nuxt preview --dotenv .env.femo",
    "preview:lingaphone": "nuxt preview --dotenv .env.lingaphone",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck --dotenv .env.lingaphone",
    "typecheck:femo": "nuxt typecheck --dotenv .env.femo",
    "typecheck:lingaphone": "nuxt typecheck --dotenv .env.lingaphone",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "supabase:types": "npx supabase gen types typescript --project-id owiaccgxbejsgtyhhtrd > ./app/shared/types/database.types.ts",
    "supabase:types:femo": "npx supabase gen types typescript --project-id wutbikqnmuifovtteylp > ./app/shared/types/database.types.ts",
    "supabase:types:lingaphone": "npx supabase gen types typescript --project-id owiaccgxbejsgtyhhtrd > ./app/shared/types/database.types.ts",
    "db:migrate:new": "npx supabase migration new",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:diff": "npx supabase db diff",
    "db:migrate": "npx supabase db push && pnpm supabase:types"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.72",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/hints": "1.0.0-alpha.10",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/test-utils": "4.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/seo": "^3.4.0",
    "@nuxtjs/supabase": "^2.0.4",
    "@sentry/node": "^10.43.0",
    "@sentry/vue": "^10.43.0",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "@vueuse/nuxt": "^14.2.1",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "form-data": "^4.0.5",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "katex": "^0.16.38",
    "mailgun.js": "^12.7.1",
    "markdown-it": "^14.1.1",
    "nuxt": "^4.3.1",
    "openai": "^6.27.0",
    "tailwindcss": "^4.2.1",
    "vue-chartjs": "^5.3.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@playwright/test": "^1.58.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "happy-dom": "^20.8.3",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.58.2",
    "supabase": "^2.84.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.30.3"
}
