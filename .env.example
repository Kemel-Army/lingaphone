# ===========================================
# FEMO — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Optional aliases for compatibility across Nuxt/Next projects
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# Used by Supabase CLI for local dev
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Mailgun (email notifications) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# --- Payment Gateway ---
PAYMENT_API_KEY=
KASPI_MERCHANT_ID=
EPAY_MERCHANT_ID=
APP_URL=https://femo.kz

# --- Internal API key (shared secret for server-to-server $fetch) ---
# Required: server-internal routes (update-quest-progress) refuse to run
# without this. Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# --- Sentry (error monitoring) ---
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- TURN Server (WebRTC) ---
TURN_SERVER_URL=turn:turn.example.com:3478
TURN_SERVER_USER=
TURN_SERVER_CREDENTIAL=

# --- Supabase CLI (for type generation) ---
SUPABASE_PROJECT_ID=your-project-id
